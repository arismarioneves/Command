# Configuração do Command
# Copie este arquivo para .env e configure suas variáveis

# Provider de IA: ollama (local) ou openai (online)
PROVIDER=ollama

# Modelo atual — pode ser alterado com o comando : dentro do terminal
MODELO_ATUAL=qwen2.5:3b  # para ollama; use gpt-5-nano para openai

# Chave da API OpenAI (obrigatória somente para PROVIDER=openai)
# Obtenha em: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# Nome do usuário no prompt (opcional)
USUARIO=root
